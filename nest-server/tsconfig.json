{
	"compilerOptions": {
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"target": "ES2021",
		"module": "commonjs",
		"moduleResolution": "node",
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"paths": {
			"@prisma/__generated__": [
				"node_modules/@prisma/__generated__/client.ts"
			],
			"@prisma/__generated__/client": [
				"node_modules/@prisma/__generated__/client.ts"
			],
			"@prisma/__generated__/*": ["node_modules/@prisma/__generated__/*"]
		},
		"incremental": true,
		"skipLibCheck": true,
		"strictNullChecks": false,
		"noImplicitAny": false,
		"strictBindCallApply": false,
		"jsx": "react"
	}
}
